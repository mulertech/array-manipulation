{
  "name": "mulertech/array-manipulation",
  "description": "This class manipulates and organizes arrays",
  "type": "library",
  "keywords": ["php", "array", "manipulation", "utility"],
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Sébastien Muler",
      "email": "sebastien.muler@mulertech.net"
    }
  ],
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "mulertech/docker-dev": "^3.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12",
    "roave/security-advisories": "dev-latest"
  },
  "config": {
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "MulerTech\\ArrayManipulation\\": "./src"
    }
  },
    "autoload-dev": {
        "psr-4": {
        "MulerTech\\ArrayManipulation\\Tests\\": "./tests"
        }
    }
}
